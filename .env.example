# Copy this file to .env and fill in your values.
# Vite exposes VITE_* variables to the browser UI at serve/build time.
# Variables without VITE_ are used when importing the package in Node.js.

# ── LLM ────────────────────────────────────────────────────────────────────────
VITE_LLM_API_KEY=sk-...
VITE_LLM_BASE_URL=https://api.openai.com/v1
VITE_LLM_MODEL=gpt-4o
VITE_LLM_TEMPERATURE=0.7
VITE_LLM_MAX_TOKENS=512

# Optional: override the system prompt (single line; newlines not supported in .env)
# VITE_LLM_SYSTEM_PROMPT=You are a helpful voice assistant...

# ── TTS (Kokoro) ───────────────────────────────────────────────────────────────
# Voices: af_heart af_bella af_sarah am_adam am_michael bf_emma bm_george
VITE_TTS_VOICE=af_heart
VITE_TTS_SPEED=1.0

# ── STT (Moonshine) ────────────────────────────────────────────────────────────
# moonshine/tiny  (faster, less accurate)
# moonshine/base  (slower, more accurate)
VITE_STT_MODEL=moonshine/tiny

# ── Node.js package use (no VITE_ prefix needed) ──────────────────────────────
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
